{
  "name": "judgy-calculator",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run tests/unit",
    "test:watch": "vitest tests/unit",
    "test:e2e": "npm run build && vitest run tests/e2e",
    "package": "npm run build && node scripts/package.mjs",
    "screenshots": "npm run build && node scripts/store-shots.mjs"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@fontsource/press-start-2p": "^5.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "adm-zip": "^0.6.0",
    "fast-check": "^4.9.0",
    "jsdom": "^29.1.1",
    "puppeteer-core": "^25.3.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
